# OpenAI API key for embeddings (default: text-embedding-3-large, 3072 dimensions)
OPENAI_API_KEY=your-openai-key

# Optional: DashScope API key for legacy embeddings / rerank / vision helpers
DASHSCOPE_API_KEY=your-dashscope-key

# Optional embedding overrides
SORTPAPER_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
SORTPAPER_EMBEDDING_DIM=3072

# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-key
