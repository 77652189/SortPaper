# DashScope API key for default embeddings (text-embedding-v3) / rerank / vision helpers
DASHSCOPE_API_KEY=your-dashscope-key

# Optional embedding overrides
SORTPAPER_EMBEDDING_PROVIDER=dashscope
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
SORTPAPER_EMBEDDING_DIM=1024
SORTPAPER_QDRANT_COLLECTION=papers
SORTPAPER_RERANK_DEFAULT_ENABLED=true
SORTPAPER_SELECTIVE_RERANK_DEFAULT_ENABLED=false

# Optional local Qwen3 embedding provider.
# Use a separate/rebuilt Qdrant collection; do not mix local Qwen3 query vectors with
# existing DashScope/OpenAI-ingested vectors when evaluating recall.
# SORTPAPER_EMBEDDING_PROVIDER=qwen3_local
# SORTPAPER_QDRANT_COLLECTION=papers_qwen3_local
# SORTPAPER_SELECTIVE_RERANK_DEFAULT_ENABLED=true
# QWEN3_LOCAL_EMBEDDING_MODEL_PATH=data/models/Qwen3-Embedding-0.6B
# QWEN3_LOCAL_EMBEDDING_MAX_LENGTH=8192
# QWEN3_LOCAL_EMBEDDING_QUERY_INSTRUCT=Given a scientific paper search query, retrieve relevant passages that answer the query.

# Optional OpenAI embedding override
OPENAI_API_KEY=your-openai-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1

# DeepSeek API key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your-deepseek-key

# MinerU API key for external PDF extraction smoke tests
MINERU_API_KEY=your-mineru-api-key
MINERU_API_BASE_URL=https://mineru.net
MINERU_MODEL_VERSION=vlm
MINERU_FIGURE_VISION_MAX_WORKERS=2

# Optional external paper import settings
SORTPAPER_EXTERNAL_CONTACT_EMAIL=your-contact@example.com
NCBI_API_KEY=your-ncbi-api-key
SORTPAPER_EXTERNAL_HTTP_TIMEOUT_SECONDS=20
SORTPAPER_EXTERNAL_MAX_PDF_MB=50
SORTPAPER_EXTERNAL_MONITOR_AUTO_RUN=true
SORTPAPER_DAILY_BRIEF_SMALL_MODEL=deepseek-chat
SORTPAPER_DAILY_BRIEF_JUDGE_MODEL=deepseek-v4-pro
SORTPAPER_DAILY_BRIEF_MAX_WORKERS=4
SORTPAPER_DAILY_BRIEF_TRANSLATION_MODEL=gpt-5.5-mini
SORTPAPER_DAILY_BRIEF_TRANSLATION_MAX_CHARS=4000
SORTPAPER_DAILY_BRIEF_TRANSLATION_MAX_WORKERS=4
SORTPAPER_DAILY_BRIEF_TRANSLATION_BATCH_SIZE=4
OPENAI_CHAT_BASE_URL=https://api.openai.com/v1
